{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "#000000",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"cinelink-backend\"}[5m]))",
          "legendFormat": "requests/sec",
          "refId": "A"
        }
      ],
      "title": "Request Rate (requests/sec)",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"cinelink-backend\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "P95 Request Latency (seconds)",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 6 },
      "id": 3,
      "options": {},
      "targets": [
        {
          "expr": "(sum(rate(cache_hits_total{job=\"cinelink-backend\"}[5m])))/(sum(rate(cache_hits_total{job=\"cinelink-backend\"}[5m])) + sum(rate(cache_misses_total{job=\"cinelink-backend\"}[5m])))",
          "legendFormat": "cache_hit_ratio",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Ratio",
      "type": "gauge"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 6 },
      "id": 4,
      "options": {},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"cinelink-backend\"}[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Requests by Status (5m rate)",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 6 },
      "id": 5,
      "options": {},
      "targets": [{ "expr": "up{job=\"cinelink-backend\"}", "legendFormat": "up", "refId": "A" }],
      "title": "Backend Up",
      "type": "stat"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["cinelink", "backend", "prometheus"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "CineLink Backend - Prometheus",
  "uid": "cinelink-backend-prom",
  "version": 1,
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ]
}
